# App
APP_PORT=8080
APP_TZ=UTC

# MariaDB
DB_PORT=3306

# MariaDB container credentials
MARIADB_ROOT_PASSWORD=CHANGE_ME_ROOT
MARIADB_DATABASE=i18n
MARIADB_USER=i18n
MARIADB_PASSWORD=CHANGE_ME_USER

# App DB connection (optional overrides; defaults to MARIADB_* if empty)
DB_NAME=
DB_USER=
DB_PASSWORD=

# Bundle storage inside container
APP_BUNDLE_STORAGE_BASE_PATH=/data/i18n
