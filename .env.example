# App
APP_PORT=8080
I18NPORT=8080
APP_TZ=UTC

# MariaDB
I18N_DB_PORT=3306

# MariaDB container credentials
MARIADB_ROOT_PASSWORD=CHANGE_ME_ROOT
MARIADB_DATABASE=i18n
MARIADB_USER=i18n
MARIADB_PASSWORD=CHANGE_ME_USER

# App DB connection (optional overrides; defaults to MARIADB_* if empty)
I18N_DB_HOST=
I18N_DB_NAME=
I18N_DB_USER=
I18N_DB_PASSWORD=

# Bundle storage inside container
APP_BUNDLE_STORAGE_BASE_PATH=/data/i18n

# Security JWT (set one of issuer/jwks)
SECURITY_JWT_ISSUER_URI=
SECURITY_JWT_ISSUER=
SECURITY_JWT_JWKS_URI=
SECURITY_JWT_AUDIENCE=i18n-service
APP_RUNTIME_PUBLIC=false
